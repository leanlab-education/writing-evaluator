generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth
// ============================================

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  hashedPassword String?
  role           Role     @default(EVALUATOR)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projects              ProjectEvaluator[]
  scores                Score[]
  batchAssignments      BatchAssignment[]
  teamMemberships       EvaluatorTeamMember[]
  adjudicatedBatches    Batch[]        @relation("BatchAdjudicator")
  teamBatchReleases     TeamBatchRelease[] @relation("TeamBatchReleaseScorer")
  escalationsCreated    Escalation[]   @relation("EscalationEscalatedBy")
  escalationsResolved   Escalation[]   @relation("EscalationResolvedBy")
}

enum Role {
  ADMIN
  EVALUATOR
}

model AuthToken {
  id        String        @id @default(cuid())
  email     String
  token     String        @unique
  type      AuthTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
}

enum AuthTokenType {
  INVITE
  RESET
}

// ============================================
// Projects
// ============================================

model Project {
  id                   String        @id @default(cuid())
  name                 String
  description          String?
  status               ProjectStatus @default(SETUP)
  discrepancyThreshold Int           @default(1)
  studyflowStudyId     String?       // Links to a StudyFlow study for participant import
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  rubric        RubricDimension[]
  feedbackItems FeedbackItem[]
  evaluators    ProjectEvaluator[]
  assignments   Assignment[]
  batches       Batch[]
  teams         EvaluatorTeam[]
  imports       Import[]
}

enum ProjectStatus {
  SETUP
  ACTIVE
  RECONCILIATION
  COMPLETE
}

// ============================================
// Rubric (configurable per project)
// ============================================

model RubricDimension {
  id             String  @id @default(cuid())
  projectId      String
  key            String
  label          String
  description    String?
  sortOrder      Int
  scaleMin       Int     @default(0)
  scaleMax       Int     @default(1)
  scoreLabelJson String? // JSON keyed by score value: {"0":{"label":"Does Not Meet Criterion"},"1":{"label":"Meets Criterion"}}
  guidanceJson   String? // JSON: prompt + ordered content blocks for full-rubric display

  project        Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scores         Score[]
  teamDimensions EvaluatorTeamDimension[]
  escalations    Escalation[]

  @@unique([projectId, key])
}

// ============================================
// Feedback Items (imported from CSV)
// ============================================

model FeedbackItem {
  id             String         @id @default(cuid())
  projectId      String
  responseId     String?        // Response_ID from CSV (L1↔L2 linkage key)
  cycleId        String?
  studentId      String
  activityId     String?        // Activity_ID (which Quill activity)
  conjunctionId  String?        // Conjunction_ID ("But" or "Because")
  studentText    String
  feedbackId     String
  teacherId      String?
  feedbackText   String
  feedbackSource FeedbackSource
  optimal        String?
  feedbackType   String?
  batchId        String?        // FK to Batch (null = unassigned to batch)
  importId       String?        // FK to Import (which upload brought this item in)
  displayOrder   Int?
  slotIndex      Int?           // 0 or 1 — which teammate slot scores this item in non-double-scored regular batches
  createdAt      DateTime       @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  batch       Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  import      Import?      @relation(fields: [importId], references: [id], onDelete: SetNull)
  assignments Assignment[]
  scores      Score[]
  escalations Escalation[]

  @@unique([projectId, feedbackId])
}

enum FeedbackSource {
  AI
  HUMAN
}

// ============================================
// Evaluator Assignments
// ============================================

model ProjectEvaluator {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@unique([projectId, userId])
}

model Assignment {
  id             String           @id @default(cuid())
  projectId      String
  evaluatorId    String
  feedbackItemId String
  status         AssignmentStatus @default(PENDING)
  createdAt      DateTime         @default(now())

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evaluator    ProjectEvaluator @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
  feedbackItem FeedbackItem     @relation(fields: [feedbackItemId], references: [id], onDelete: Cascade)

  @@unique([evaluatorId, feedbackItemId])
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

// ============================================
// Batches (groups of items for evaluator assignment)
// ============================================

model Batch {
  id             String      @id @default(cuid())
  projectId      String
  name           String                       // e.g. "Activity 1 / Because / Batch 3"
  activityId     String?                      // Quill activity this batch covers
  conjunctionId  String?                      // "But" or "Because"
  type           BatchType   @default(REGULAR)
  isDoubleScored Boolean     @default(false)
  status         BatchStatus @default(DRAFT)
  size           Int         @default(250)    // Target batch size
  isAssigned     Boolean     @default(false)  // Locked after first evaluator assignment
  sortOrder      Int         @default(0)
  adjudicatorId  String?                      // Third-person tiebreaker for escalated discrepancies
  isHidden       Boolean     @default(false)  // Hide from annotators (e.g. release Independent batches only after Double-Scored IRR passes)
  createdAt      DateTime    @default(now())

  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adjudicator   User?             @relation("BatchAdjudicator", fields: [adjudicatorId], references: [id], onDelete: SetNull)
  feedbackItems FeedbackItem[]
  ranges        BatchRange[]
  assignments   BatchAssignment[]
  teamReleases  TeamBatchRelease[]
  escalations   Escalation[]
}

enum BatchStatus {
  DRAFT       // Created but not yet open for scoring
  SCORING     // Evaluators can score items
  RECONCILING // Double-scoring complete, team reconciling discrepancies
  COMPLETE    // Done, scores locked
}

enum BatchType {
  REGULAR   // Normal scoring — evaluator sees only their team's criteria
  TRAINING  // All evaluators score every rubric criterion — initial onboarding before teams are assigned
}

model BatchAssignment {
  id          String      @id @default(cuid())
  batchId     String
  userId      String
  teamReleaseId String?
  scoringRole ScoringRole @default(PRIMARY)
  createdAt   DateTime    @default(now())

  batch       Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamRelease TeamBatchRelease? @relation(fields: [teamReleaseId], references: [id], onDelete: SetNull)

  @@unique([batchId, userId])
}

enum ScoringRole {
  PRIMARY // First scorer — this is "their" batch
  DOUBLE  // Double-scoring for IRR — scoring partner's items
}

model BatchRange {
  id              String   @id @default(cuid())
  batchId         String
  startFeedbackId String
  endFeedbackId   String
  itemCount       Int
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model TeamBatchRelease {
  id           String   @id @default(cuid())
  batchId      String
  teamId       String
  scorerUserId String?
  isVisible    Boolean  @default(false)
  status       BatchStatus @default(DRAFT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batch       Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  team        EvaluatorTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scorerUser  User?             @relation("TeamBatchReleaseScorer", fields: [scorerUserId], references: [id], onDelete: SetNull)
  assignments BatchAssignment[]
  escalations Escalation[]

  @@unique([batchId, teamId])
}

// ============================================
// Evaluator Teams (pairs of evaluators assigned to specific criteria)
// ============================================

model EvaluatorTeam {
  id        String   @id @default(cuid())
  projectId String
  name      String   // e.g. "Team Alpha", "Gryffindor"
  createdAt DateTime @default(now())

  project    Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members    EvaluatorTeamMember[]
  dimensions EvaluatorTeamDimension[]
  releases   TeamBatchRelease[]

  @@unique([projectId, name])
}

model EvaluatorTeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String

  team EvaluatorTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model EvaluatorTeamDimension {
  id          String @id @default(cuid())
  teamId      String
  dimensionId String

  team      EvaluatorTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  dimension RubricDimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@unique([teamId, dimensionId])
}

// ============================================
// Scores
// ============================================

model Score {
  id              String    @id @default(cuid())
  feedbackItemId  String
  userId          String
  dimensionId     String
  value           Int
  rationale       String?
  isReconciled    Boolean   @default(false)
  reconciledFrom  String?
  notes           String?
  startedAt       DateTime?
  scoredAt        DateTime  @default(now())
  durationSeconds Int?

  feedbackItem FeedbackItem    @relation(fields: [feedbackItemId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dimension    RubricDimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@unique([feedbackItemId, userId, dimensionId, isReconciled])
}

// ============================================
// Imports (rolling CSV upload provenance)
// ============================================

// Each CSV upload creates an Import row so admins can see a history and
// scope batch creation to a single upload ("batch only the items from
// today's whales/because upload"). Duplicates are skipped on import via
// the @@unique([projectId, feedbackId]) constraint on FeedbackItem.
model Import {
  id           String   @id @default(cuid())
  projectId    String
  filename     String
  itemCount    Int      // Rows successfully imported by this upload
  skippedCount Int      // Rows skipped because the Feedback_ID already existed
  createdAt    DateTime @default(now())

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feedbackItems FeedbackItem[]
}

// ============================================
// Escalations (third-person tiebreaker for discrepancies)
// ============================================

// When a pair reconciling a Double-Scored batch cannot agree on a specific
// criterion of an item, they escalate that criterion to the batch's
// adjudicator. Per Amber's 2026-04-09 note: "each criterion is standalone"
// so escalation is per-(item, dimension), not per-item.
//
// The adjudicator resolves each escalated criterion by writing an
// isReconciled Score row (same audit trail pattern as pair-resolved items).
// The rationale is captured in the pair's "Why we decided what we did"
// reconciliation notes, not a separate escalation-reason field.
model Escalation {
  id             String    @id @default(cuid())
  batchId        String
  teamReleaseId  String
  feedbackItemId String
  dimensionId    String    // Per-criterion scope — Amber 2026-04-09
  escalatedById  String    // userId of the pair member who clicked Escalate
  resolvedById   String?   // adjudicator userId
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  batch        Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  teamRelease  TeamBatchRelease @relation(fields: [teamReleaseId], references: [id], onDelete: Cascade)
  feedbackItem FeedbackItem     @relation(fields: [feedbackItemId], references: [id], onDelete: Cascade)
  dimension    RubricDimension  @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  escalatedBy  User             @relation("EscalationEscalatedBy", fields: [escalatedById], references: [id], onDelete: Cascade)
  resolvedBy   User?            @relation("EscalationResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([teamReleaseId, feedbackItemId, dimensionId])
}
